---
open_move: true
open_vis: true
map_view_detail_frame:  pit
visuals:
- pass: bg
  type: simple_floor
  opts:
    atlas: main
    tile: dun2fire-floor
- pass: bg
  type: simple_ceiling
  opts:
    atlas: main
    tile: dun2fire-ceiling
- pass: celldetails
  type: simple_billboard
  opts:
    atlas: main
    tile: [fire1, fire2]
    width: 0.85
    height: 0.65
    offs: [0, 0, 0]
    face_camera: false # Otherwise faces frustum
    do_alpha: true
