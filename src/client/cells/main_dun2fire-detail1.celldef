---
open_move: true
open_vis: true
visuals:
- pass: bg
  type: simple_floor
  opts:
    atlas: main
    tile: dun2fire-floor
- pass: bg
  type: simple_ceiling
  opts:
    atlas: main
    tile: dun2fire-ceiling
- pass: celldetails
  type: simple_billboard
  opts:
    atlas: main
    tile: dun2fire-detail1
    width: 0.35
    height: 0.35
    offs: [-0.29, 0.21, 0]
    face_camera: false # Otherwise faces frustum
    do_alpha: true
