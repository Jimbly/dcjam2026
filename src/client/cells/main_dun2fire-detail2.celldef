---
open_move: true
open_vis: true
sound_id: footstep_fire
visuals:
- pass: bg
  type: simple_floor
  opts:
    atlas: main
    tile: dun2fire-floor
- pass: bg
  type: simple_ceiling
  opts:
    atlas: main
    tile: dun2fire-ceiling
- pass: celldetails
  type: simple_billboard
  opts:
    atlas: main
    tile: dun2fire-detail2
    width: 0.40
    height: 0.40
    offs: [0.25, -0.27, 0]
    face_camera: false # Otherwise faces frustum
    do_alpha: true
