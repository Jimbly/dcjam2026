---
open_move: false
open_vis: true
visuals:
- pass: bg
  type: simple_floor
  opts:
    atlas: main
    tile: dun9-floor
- pass: bg
  type: simple_ceiling
  opts:
    atlas: main
    tile: dun9-ceiling
- pass: celldetails
  type: simple_billboard
  opts:
    atlas: main
    tile: dun9-detail1
    width: 0.5
    height: 0.5
    offs: [0, 0, 0]
    face_camera: false # Otherwise faces frustum
