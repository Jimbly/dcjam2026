---
open_move: true
open_vis: true
sound_id: footstep_water
visuals:
- pass: bg
  type: simple_floor
  opts:
    atlas: main
    tile: dun9-floor
- pass: bg
  type: simple_ceiling
  opts:
    atlas: main
    tile: dun9-ceiling
- pass: celldetails
  type: simple_billboard
  opts:
    atlas: main
    tile: dun9-detail1
    width: 0.25
    height: 0.25
    offs: [0.2, 0.1, 0]
    face_camera: false # Otherwise faces frustum
    do_alpha: true
